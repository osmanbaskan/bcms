# BCMS Intermediate CA — openssl config
# Used by: infra/tls/scripts/generate-ca.sh
# Validity: 5 years
# Key: ECDSA secp384r1
# Hash: SHA-384
#
# Intermediate CA server cert'lerini imzalar. Online operasyonel kullanımda.
# Root CA tarafından imzalanır, root key offline kalır.

[req]
distinguished_name = req_distinguished_name
prompt             = no
default_md         = sha384

[req_distinguished_name]
CN = BCMS Internal Intermediate CA
O  = BCMS Internal
C  = TR

[v3_intermediate_ca]
basicConstraints       = critical, CA:TRUE, pathlen:0
keyUsage               = critical, digitalSignature, cRLSign, keyCertSign
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid:always, issuer:always
