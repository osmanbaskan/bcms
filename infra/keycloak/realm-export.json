      "credentials": [{ "type": "password", "value": "planner123", "temporary": true }],
      "realmRoles": ["planner"]
    },
    {
      "username": "viewer1",
      "email": "viewer1@bcms.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "viewer123", "temporary": true }],
      "realmRoles": ["viewer"]
    }
