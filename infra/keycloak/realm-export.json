{
  "realm": "bcms",
  "enabled": true,
  "displayName": "BCMS",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "bruteForceProtected": true,
  "accessTokenLifespan": 1800,
  "groups": [
    { "name": "Tekyon" },
    { "name": "Transmisyon" },
    { "name": "Booking" },
    { "name": "YayınPlanlama" },
    { "name": "SystemEng" },
    { "name": "Ingest" },
    { "name": "Kurgu" },
    { "name": "MCR" },
    { "name": "PCR" },
    { "name": "Ses" }
  ],
  "roles": {
    "realm": [
      { "name": "admin",            "description": "Full system access" },
      { "name": "planner",          "description": "Create/edit schedules and bookings" },
      { "name": "scheduler",        "description": "Manage broadcast schedule" },
      { "name": "ingest_operator",  "description": "Manage ingest jobs" },
      { "name": "monitoring",       "description": "View monitoring dashboards" },
      { "name": "viewer",           "description": "Read-only access" }
    ]
  },
  "clients": [
    {
      "clientId": "bcms-api",
      "name": "BCMS API",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "bcms-web",
      "name": "BCMS Web",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:4200/*",
        "http://172.28.204.133:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://172.28.204.133:4200"
      ],
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@bcms.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "admin123", "temporary": true }],
      "realmRoles": ["admin"]
    },
    {
      "username": "planner1",
