# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=bcms_user
POSTGRES_PASSWORD=changeme_db
POSTGRES_DB=bcms
KEYCLOAK_DB=keycloak
DATABASE_URL=postgresql://bcms_user:changeme_db@postgres:5432/bcms

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=bcms
RABBITMQ_PASSWORD=changeme_mq
RABBITMQ_URL=amqp://bcms:changeme_mq@rabbitmq:5672

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_kc
KEYCLOAK_REALM=bcms
KEYCLOAK_CLIENT_ID=bcms-api
KEYCLOAK_ALLOWED_ISSUERS=http://localhost:8080/realms/bcms
KEYCLOAK_ALLOWED_CLIENTS=bcms-api,bcms-web
BCMS_KEYCLOAK_PUBLIC_URL=http://localhost:8080
KC_HOSTNAME=localhost
KC_HOSTNAME_PORT=8080

# ── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
# WARNING: SKIP_AUTH must be false in production. Double-guarded in app.ts + auth.ts.
SKIP_AUTH=true
CORS_ORIGIN=http://localhost:4200,http://172.28.204.133:4200
INGEST_CALLBACK_SECRET=change_this_dev_secret
OPTA_SYNC_SECRET=change_this_dev_secret
OPTA_WATCHER_API_TOKEN=change_this_dev_secret
AUDIT_RETENTION_DAYS=90

# ── Directories ───────────────────────────────────────────────────────────────
BXF_WATCH_DIR=/mnt/bxf
PROXY_OUTPUT_DIR=/mnt/proxies
WATCH_FOLDER=/mnt/ingest
OPTA_DIR=/mnt/opta-backups/OPTAfromFTP20511

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=changeme_grafana

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bcms.local

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_HOST=172.26.34.200

# ── OPTA SMB ──────────────────────────────────────────────────────────────────
OPTA_SMB_SHARE=//server/share
OPTA_SMB_SUBDIR=OPTAfromFTP20511
OPTA_SMB_MOUNT_POINT=/mnt/opta-backups
OPTA_SMB_USERNAME=
OPTA_SMB_PASSWORD=
OPTA_SMB_DOMAIN=
OPTA_POLL_INTERVAL=3600
