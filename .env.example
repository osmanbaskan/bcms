# BCMS .env.example — production'a deploy ederken her <GENERATE_ME> değerini
# güçlü random ile doldur. SKIP_AUTH bu dosyada YOK; sadece dev .env'de gerekirse
# eklenir ve validateRuntimeEnv() prod'da bu env'in olmadığını verify eder.
#
# HIGH-INF-014 fix (2026-05-05):
#   - SKIP_AUTH satırı kaldırıldı (prod'da olmaması gereken bir env idi)
#   - NODE_ENV varsayılanı production
#   - changeme_* placeholder'lar <GENERATE_ME> ile değiştirildi (silah olarak
#     kopyalanma riski azalır)

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=bcms_user
POSTGRES_PASSWORD=<GENERATE_ME_db>            # openssl rand -base64 24
POSTGRES_DB=bcms
KEYCLOAK_DB=keycloak
DATABASE_URL=postgresql://bcms_user:<GENERATE_ME_db>@postgres:5432/bcms

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=bcms
RABBITMQ_PASSWORD=<GENERATE_ME_mq>            # openssl rand -base64 24
RABBITMQ_URL=amqp://bcms:<GENERATE_ME_mq>@rabbitmq:5672

# ── Keycloak ──────────────────────────────────────────────────────────────────
# TLS reverse proxy mimarisi (2026-05-04): Browser https://beinport/ üzerinden gelir,
# nginx TLS termine eder, /realms/, /admin/ path'lerini Keycloak'a proxy'ler.
# Internal: KEYCLOAK_URL Docker network içi (HTTP).
# Public:   KC_HOSTNAME + BCMS_KEYCLOAK_PUBLIC_URL nginx'in browser'a yansıttığı isim/URL.
# Bkz: ops/REQUIREMENTS-TLS-INTERNAL-CA.md
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<GENERATE_ME_kc>      # openssl rand -base64 32
KEYCLOAK_REALM=bcms
KEYCLOAK_CLIENT_ID=bcms-api
KEYCLOAK_ISSUER=https://beinport/realms/bcms
KEYCLOAK_ALLOWED_ISSUERS=https://beinport/realms/bcms,http://localhost:8080/realms/bcms
KEYCLOAK_ALLOWED_CLIENTS=bcms-api,bcms-web
BCMS_KEYCLOAK_PUBLIC_URL=https://beinport
KC_HOSTNAME=beinport
# KC_HOSTNAME_PORT=-1: 443 standart HTTPS portu, issuer URL'ye eklenmez
KC_HOSTNAME_PORT=-1
KC_HOSTNAME_STRICT=true
KC_HOSTNAME_STRICT_HTTPS=true

# ── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
# DİKKAT: SKIP_AUTH env'i bu dosyada YOK ve OLMAMALI. Local dev'de gerekirse
# .env'e ekleyin ve sadece "true" değerle bırakın; prod'da boş veya yok olmalı.
# validateRuntimeEnv() + authPlugin prod'da SKIP_AUTH=true'yu engeller.
CORS_ORIGIN=https://beinport
INGEST_CALLBACK_SECRET=<GENERATE_ME_ingest>   # openssl rand -hex 32
OPTA_SYNC_SECRET=<GENERATE_ME_opta_sync>      # openssl rand -hex 32
OPTA_WATCHER_API_TOKEN=<GENERATE_ME_opta_token>  # openssl rand -hex 32
AUDIT_RETENTION_DAYS=90
# Log seviyesi (fastify-pino). debug/info/warn/error. Production: info default.
LOG_LEVEL=info

# ── Outbox poller (Madde 2+7 PR-C1 — Phase 3 prereq bring-up) ────────────────
# Varsayılan: disabled. Production'da PR-C1 deploy ile true; PR-C2 cut-over'a
# kadar shadow yazımları status='published' olduğundan poller idle çalışır.
OUTBOX_POLLER_ENABLED=false
# Dry-run: pick + log; publish/state update yapmaz (smoke verification için).
OUTBOX_POLLER_DRY_RUN=false
# PR-C2 authoritative cut-over (2026-05-11): true ise outbox shadow yazımı
# status='pending' olur ve poller'a düşer. false → eski direct-publish davranışı.
# Production'da PR-C2 sonrası true; rollback için anlık false geri dönüş güvenli.
OUTBOX_POLLER_AUTHORITATIVE=false

# ── DEV ortamı için opsiyonel (production'da boş bırakılır) ──────────────────
# DEV_USER_GROUPS: SKIP_AUTH=true iken DEV_USER hangi gruplarla simüle edilsin.
# CSV; default [SystemEng]. Örnek: DEV_USER_GROUPS=Admin,Tekyon
# DEV_USER_GROUPS=
# DEV_USER_NAME=
# DEV_USER_EMAIL=

# ── Prisma pool tunables (opsiyonel — default 10/5/5sn) ──────────────────────
# PRISMA_CONNECTION_LIMIT_API=10
# PRISMA_CONNECTION_LIMIT_WORKER=5
# PRISMA_POOL_TIMEOUT=5

# ── Ingest worker tunables ────────────────────────────────────────────────────
# PROXY_OUTPUT_DIR=/var/lib/bcms/proxies   # absolute, persistent volume

# ── Directories ───────────────────────────────────────────────────────────────
BXF_WATCH_DIR=/mnt/bxf
PROXY_OUTPUT_DIR=/mnt/proxies
WATCH_FOLDER=/mnt/ingest
OPTA_DIR=/mnt/opta-backups/OPTAfromFTP20511

# ── Provys İçerik Kontrol ─────────────────────────────────────────────────────
# Host tarafında elle CIFS ile mount edilmiş SMB path. Docker bind volume
# olarak worker'a salt-okunur bağlanır. SMB credential repo'ya KONMAZ;
# host /etc/fstab veya `mount -t cifs` ile ops sorumluluğunda yönetilir.
# (Kaynak SMB dizini: //172.26.33.245/mcr/PROVYS/MANUEL/Playout/Inbox/Success/)
PROVYS_HOST_MOUNT=/mnt/provys
# Container içindeki path — compose'da bind hedefi olarak kullanılır.
PROVYS_WATCH_FOLDER=/app/tmp/provys
# SSE heartbeat aralığı (ms) — proxy/nginx idle-timeout altında kalsın.
PROVYS_SSE_HEARTBEAT_MS=25000
# CIFS/SMB mount'larda inotify event'leri başka client yazımları için
# güvenilir gelmez; polling moduna alır. Lokal disk'te `false` bırakılabilir.
PROVYS_WATCHER_USE_POLLING=true
# Polling moduyken keşif aralığı (ms). 30 sn varsayılan; çok düşürmek IO
# yükünü artırır, çok yükseltmek dosya görünmesini geciktirir.
PROVYS_WATCHER_POLL_INTERVAL_MS=30000
# P1.6 (2026-05-29, 250 user scale): /provys/restore-missing today-future
# scope üst sınırı (gün). Default 14 (BXF importer 7-14 gün öncesinden yazar);
# max 60 (clamp). Düşürmek payload boyutunu azaltır (tipik 1 MB → 200 KB).
PROVYS_RESTORE_FUTURE_DAYS=14

# ── Asrun (playout sonrası as-run kayıt) ─────────────────────────────────────
# Host tarafında elle CIFS mount edilen path. SMB kaynağı:
#   //172.26.33.245/mcr/PROVYS/FTP-PROVYS/Playout/Outbox/Ok/
# Credential repo'ya KONMAZ; ops elle mount eder.
ASRUN_HOST_MOUNT=/mnt/asrun-ok
# Container içinde Asrun BXF dizini — worker'a salt-okunur bind.
ASRUN_WATCH_FOLDER=/app/tmp/asrun
# Provys ile aynı sebep — CIFS inotify güvensiz, polling tercih edilir.
ASRUN_WATCHER_USE_POLLING=true
ASRUN_WATCHER_POLL_INTERVAL_MS=30000
ASRUN_WATCHER_DEBOUNCE_MS=1500
ASRUN_WATCHER_CONCURRENCY=3

# ── Monitoring ────────────────────────────────────────────────────────────────
# Production: en az 24 karakter, random. Üretim: openssl rand -base64 24
# Dev .env'de "changeme_*" sabit string kabul; docker-compose GRAFANA_PASSWORD:?must_be_set ile bos engellenmis.
GRAFANA_PASSWORD=<GENERATE_ME_grafana>

# ── AlertManager (K15, 2026-05-29) ────────────────────────────────────────────
# Prometheus alert fire ettiğinde email + Slack push. Email kanalı her zaman
# aktif (mevcut SMTP_* env'lerini kullanır). Slack kanalı SLACK_WEBHOOK_URL
# set edilince aktif olur.
#
# Email alıcı: alert mailleri bu adrese düşer. Dev: ops@bcms.local (mailhog).
# Prod: gerçek inbox (örn. ops-alerts@yourcompany.com).
ALERT_EMAIL_TO=ops@bcms.local
#
# Slack webhook URL: https://api.slack.com/messaging/webhooks ile oluştur.
# Format: https://hooks.slack.com/services/T.../B.../X...
# Boş bırakılırsa AlertManager Slack receiver'a istek atar ama 404 alır
# (warn log + crash YOK; email yine çalışır).
SLACK_WEBHOOK_URL=
# ÖNEMLİ-API-1.1.20 (2026-05-04): /metrics application-katmanı koruması.
# Set edilirse Bearer <token> zorunlu; boş bırakılırsa nginx deny tek katman.
# Prometheus container scrape config'inde aynı token kullanılır.
METRICS_TOKEN=<GENERATE_ME_metrics>           # openssl rand -hex 32

# ── Prometheus Basic Auth (GitGuardian fix 2026-05-04) ───────────────────────
# Prometheus web-config.yml `basic_auth_users` ile UI/API erişimini koruyor.
# İki değer de aynı plaintext password'den türetilir; rotate'ta ikisini de yenile.
#
# 1. Plaintext password: openssl rand -base64 24
# 2. PROMETHEUS_BASIC_AUTH_HASH = htpasswd -nbBC 10 admin <plaintext> | cut -d: -f2
#    web-config.yml'e elle yazılır (Prometheus env substitution desteklemez).
# 3. PROMETHEUS_HEALTHCHECK_AUTH_B64 = echo -n "admin:<plaintext>" | base64
#    docker-compose healthcheck için gerekli — env üzerinden inject edilir.
#
# Bkz: ops/RUNBOOK-SECRETS-ROTATION.md
PROMETHEUS_HEALTHCHECK_AUTH_B64=<GENERATE_ME_prom_b64>
PROMETHEUS_BASIC_AUTH_HASH=<GENERATE_ME_prom_bcrypt_hash>

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
# TLS (STARTTLS yerine implicit TLS). Mailhog dev: false; production: provider'a göre (genelde 465 + true).
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bcms.local

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_HOST=172.26.34.200

# ── OPTA SMB ──────────────────────────────────────────────────────────────────
OPTA_SMB_SHARE=//server/share
OPTA_SMB_SUBDIR=OPTAfromFTP20511
OPTA_SMB_MOUNT_POINT=/mnt/opta-backups
OPTA_SMB_USERNAME=
OPTA_SMB_PASSWORD=
OPTA_SMB_DOMAIN=
OPTA_POLL_INTERVAL=3600

# ── SSDB MAM (Provys DC → MAM materyal kontrol) ──────────────────────────────
# `on` ile worker tick periodic SSDB lookup yapar + API /ssdb/* endpointleri
# aktif. Default `off`. read-only SQL Server kullanıcısı (sadece SELECT).
PROVYS_SSDB_RESOLVER=off
SSDB_HOST=172.28.208.20
SSDB_PORT=60813
SSDB_DATABASE=LIGTV-SSDB
SSDB_USER=read1
SSDB_PASSWORD=<GENERATE_ME_ssdb_read_password>
# Opsiyonel — V1 default'lar yeterli (2026-05-27 revize):
# SSDB_DEFAULT_FPS=25
# SSDB_WINDOW_FUTURE_DAYS=14
# Worker periyodik interval: 1 saat (önceden 60sn). UI/API canlı SSDB
# sorgusu YOK; Provys BXF sync sonrası ayrıca tetiklenir (debounce 5sn,
# coalesce/serial).
# SSDB_WORKER_INTERVAL_MS=3600000
# SSDB_WORKER_MAX_PER_TICK=100
# Found TTL 60 dk: "daha önce found olan materyal silinirse en geç 1 saat
# içinde öğrenmek istiyoruz" gerekliliği için 12h → 60 dk.
# SSDB_TTL_FOUND_MIN=60
# SSDB_TTL_MISSING_MIN=30
# SSDB_TTL_ERROR_MIN=5
# SSDB_TTL_DURATION_UNKNOWN_MIN=120
# SSDB yükünü düşük tutmak için batch/concurrency düşürüldü (5/5/5):
# SSDB_BATCH_SIZE=5
# SSDB_LOOKUP_CONCURRENCY=5        # SSDB query fan-out (default 5, max 10)
# SSDB_CACHE_WRITE_CONCURRENCY=5   # Prisma upsert (default 5, max 10; P2024 onlem)

# ---------------------------------------------------------------------------
# Restore V2 — Avid Interplay (IPWS) 3 kademeli iş akışı
# ---------------------------------------------------------------------------
# Kademe 1 (search / Assets.Search) GERÇEK IPWS'e bağlı (2026-05-31).
# Kademe 2 (restore) + 3 (transfer) henüz MOCK — ayrı PR'da bağlanacak.
#
# Flag matrisi:
#   RESTORE_AVID_MOCK=true  (veya enabled=off) → MOCK adapter (sahte veri, ağ yok).
#       Default budur; restore sekmesi env'siz çalışır.
#   RESTORE_AVID_ENABLED=on + RESTORE_AVID_MOCK=false + 4 zorunlu env dolu
#       → GERÇEK IPWS. Eksik env varsa fail-fast (parola mesajda gösterilmez).
#
# GÜVENLİK: AVID_PASSWORD repoya KONMAZ — yalnız gerçek .env'e. PoC kullanıcısı
# (PoC kullanıcısı) yandı sayılır, rotate edilmeli; production'da ayrı
# sınırlı yetkili servis hesabı kullan. Bkz: IPWS-Master-Entegrasyon-Raporu §18.
RESTORE_AVID_ENABLED=off
RESTORE_AVID_MOCK=true

# --- Gerçek IPWS bağlantısı (4 zorunlu; yalnız ENABLED+MOCK=false iken) ---
# Base URL = IPWS endpoint kökü; servis adı koda eklenir (.../services/Assets).
# DNS .local çözülemezse IP ile bypass (rapor §2.3): http://172.26.33.87/services
AVID_INTERPLAY_URL=
AVID_USER=
AVID_PASSWORD=<GENERATE_ME_avid_ipws_password>
# interplay:// URI prefix kökü (Workgroup). Örn: interplay://BSVMWG/
AVID_WORKSPACE=

# --- Search (K1) ayarları — opsiyonel (default'lar saha değerleri) ---
# Assets.Search'ün taradığı kök path. Default Projects kökü.
# AVID_SEARCH_ROOT_URI=interplay://BSVMWG/Projects/
# Workgroup adı (URI prefix kurarken). Default BSVMWG.
# AVID_WORKGROUP=BSVMWG
# SOAP istek timeout (ms). Default 30000.
# AVID_REQUEST_TIMEOUT_MS=30000

# --- Restore (K2) — Jobs.SubmitJobUsingProfile ---
# Profile string birebir eşleşmeli, boşluk/tire dahil (rapor §11.3).
# AVID_RESTORE_PROFILE=BeINSports - Partial Restore
# AVID_RESTORE_SERVICE=com.avid.dms.restore

# --- Transfer (K3) — Transfer.SendToPlayback hedefi ---
# ⚠️ SendToPlayback asset'i Avid DIŞI CANLI yayın havuzuna gönderir.
# Gerçek gönderim yalnız açık onayla.
# Operasyon kararı (2026-05-31): birincil bsvmte01/MCR, yedek bsvmte02/MCR.
# requestTransfer birincil engine başarısızsa yedeğe failover yapar.
# AVID_TRANSFER_ENGINE=bsvmte01
# AVID_TRANSFER_ENGINE_FALLBACK=bsvmte02   # boş bırakılırsa failover yok
# AVID_PLAYBACK_DEVICE=MCR
# AVID_TRANSFER_PRIORITY=NORMAL            # NORMAL | PWT | UNASSIGNED

# Search worker tuning — opsiyonel (default'lar yeterli):
# SEARCH_WORKER_INTERVAL_MS=5000
# SEARCH_MAX_PER_TICK=20
# SEARCH_CONCURRENCY=3        # default 3, clamp [1,10]
# SEARCH_MAX_ATTEMPTS=3

# Restore worker tuning — opsiyonel (default'lar yeterli):
# RESTORE_WORKER_INTERVAL_MS=5000
# RESTORE_MAX_PER_TICK=20
# RESTORE_CONCURRENCY=3       # default 3, clamp [1,10]
# RESTORE_MAX_ATTEMPTS=3

# Transfer worker tuning — opsiyonel:
# TRANSFER_WORKER_INTERVAL_MS=5000
# TRANSFER_MAX_PER_TICK=20
# TRANSFER_CONCURRENCY=3
# TRANSFER_MAX_ATTEMPTS=3
