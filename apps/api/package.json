{
  "name": "@bcms/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rm -rf dist && tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "backfill:ingest-plan-item-id": "tsx src/scripts/backfill-ingest-plan-item-id.ts",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test:integration": "vitest run --config ./vitest.integration.config.ts",
    "test:integration:watch": "vitest --config ./vitest.integration.config.ts",
    "test:integration:coverage": "vitest run --config ./vitest.integration.config.ts --coverage"
  },
  "dependencies": {
    "@bcms/shared": "*",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^1.4.1",
    "@marsaud/smb2": "^0.18.0",
    "@prisma/client": "^5.22.0",
    "amqplib": "^0.10.4",
    "chokidar": "^3.6.0",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.7.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^4.5.1",
    "fluent-ffmpeg": "^2.1.3",
    "jwks-rsa": "^3.1.0",
    "nodemailer": "^8.0.5",
    "pino": "^9.3.1",
    "prisma": "^5.22.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.16.0",
    "@types/amqplib": "^0.10.5",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "@vitest/coverage-v8": "^1.6.0",
    "pino-pretty": "^13.1.3",
    "testcontainers": "^10.16.0",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
