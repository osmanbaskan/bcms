generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model League {
  id         Int       @id @default(autoincrement())
  code       String    @unique @db.VarChar(20)
  name       String    @db.VarChar(200)
  country    String    @db.VarChar(100)
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deleted_at DateTime?
  matches    Match[]
  teams      Team[]

  @@index([metadata], type: Gin)
  @@map("leagues")
}

model Team {
  id         Int       @id @default(autoincrement())
  leagueId   Int       @map("league_id")
  name       String    @db.VarChar(200)
  shortName  String    @map("short_name") @db.VarChar(20)
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deleted_at DateTime?
  bookings   Booking[]
  league     League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@index([metadata], type: Gin)
  @@map("teams")
}

model Match {
  id              Int             @id @default(autoincrement())
  leagueId        Int             @map("league_id")
  optaUid         String?         @unique @map("opta_uid") @db.VarChar(50)
  homeTeamName    String          @map("home_team_name") @db.VarChar(100)
  awayTeamName    String          @map("away_team_name") @db.VarChar(100)
  matchDate       DateTime        @map("match_date") @db.Timestamptz(6)
  weekNumber      Int?            @map("week_number")
  season          String          @db.VarChar(20)
  venue           String?         @db.VarChar(200)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deleted_at      DateTime?
  bookings        Booking[]
  league          League          @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  schedules       Schedule[]
  livePlanEntries LivePlanEntry[]

  @@index([leagueId, matchDate])
  @@map("matches")
}

model Channel {
  id         Int               @id @default(autoincrement())
  name       String            @unique @db.VarChar(100)
  type       ChannelType
  frequency  String?           @db.VarChar(50)
  muxInfo    Json?             @map("mux_info")
  active     Boolean           @default(true)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  deleted_at DateTime?
  schedules  Schedule[]
  telemetry  SignalTelemetry[]

  @@map("channels")
}

model BroadcastType {
  id          Int        @id @default(autoincrement())
  code        String     @unique @db.VarChar(30)
  description String     @db.VarChar(200)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deleted_at  DateTime?
  schedules   Schedule[]

  @@map("broadcast_types")
}

model Schedule {
  id               Int             @id @default(autoincrement())
  channelId        Int?            @map("channel_id")
  startTime        DateTime        @map("start_time") @db.Timestamptz(6)
  endTime          DateTime        @map("end_time") @db.Timestamptz(6)
  title            String          @db.VarChar(500)
  contentId        Int?            @map("content_id")
  broadcastTypeId  Int?            @map("broadcast_type_id")
  matchId          Int?            @map("match_id")
  status           ScheduleStatus  @default(DRAFT)
  /// DB seviyesinde CHECK constraint: usage_scope IN ('broadcast', 'live-plan').
  /// Migration: 20260422000002_schedule_usage_scope_constraint.
  /// Prisma 5 native CHECK desteklemediği için bu yorum drift uyarısı görevi yapar.
  /// Yeni değer eklemek için: önce ALTER TABLE migration, sonra bu yorumu güncelle.
  /// Ek koruma katmanı: zod ScheduleUsageScopeEnum (`schedule.schema.ts`).
  usageScope       String          @default("broadcast") @map("usage_scope") @db.VarChar(30)
  reportLeague     String?         @map("report_league") @db.VarChar(200)
  reportSeason     String?         @map("report_season") @db.VarChar(30)
  reportWeekNumber Int?            @map("report_week_number")
  /// Madde 3 PR-3A (audit doc): metadata->>'optaMatchId' yerine type-safe kolon.
  /// Non-unique index — aynı OPTA match için birden fazla schedule/live-plan
  /// entry mümkün (farklı kanal, broadcast vs live-plan, vb.).
  /// Backfill: migration 20260505000001_schedule_opta_match_id_promote.
  /// Transition: dual-write ile metadata.optaMatchId paralel yazılır;
  /// PR-3B'de metadata yazımı kaldırılacak.
  optaMatchId      String?         @map("opta_match_id") @db.VarChar(50)
  finishedAt       DateTime?       @map("finished_at") @db.Timestamptz(6)
  createdBy        String          @map("created_by") @db.VarChar(100)
  version          Int             @default(1)
  metadata         Json?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deleted_at       DateTime?
  bookings         Booking[]
  incidents        Incident[]
  broadcastType    BroadcastType?  @relation(fields: [broadcastTypeId], references: [id])
  channel          Channel?        @relation(fields: [channelId], references: [id])
  match            Match?          @relation(fields: [matchId], references: [id])
  timelineEvents   TimelineEvent[]

  @@index([channelId, startTime, endTime])
  @@index([status])
  @@index([usageScope])
  @@index([usageScope, reportLeague, reportSeason, reportWeekNumber])
  @@index([broadcastTypeId])
  @@index([matchId])
  @@index([optaMatchId])
  @@map("schedules")
}

model Booking {
  id           Int           @id @default(autoincrement())
  scheduleId   Int?          @map("schedule_id")
  requestedBy  String        @map("requested_by") @db.VarChar(100)
  teamId       Int?          @map("team_id")
  matchId      Int?          @map("match_id")
  metadata     Json?
  status       BookingStatus @default(PENDING)
  version      Int           @default(1)
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deleted_at   DateTime?
  taskTitle    String?       @map("task_title") @db.VarChar(300)
  taskDetails  String?       @map("task_details")
  taskReport   String?       @map("task_report")
  userGroup    String?       @map("user_group") @db.VarChar(50)
  assigneeId   String?       @map("assignee_id") @db.VarChar(100)
  assigneeName String?       @map("assignee_name") @db.VarChar(200)
  startDate    DateTime?     @map("start_date") @db.Date
  dueDate      DateTime?     @map("due_date") @db.Date
  completedAt  DateTime?     @map("completed_at") @db.Timestamptz(6)
  match        Match?        @relation(fields: [matchId], references: [id])
  schedule     Schedule?     @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  team         Team?         @relation(fields: [teamId], references: [id])

  @@index([scheduleId])
  @@index([teamId])
  @@index([matchId])
  @@index([userGroup])
  @@index([assigneeId])
  @@index([startDate, dueDate])
  @@map("bookings")
}

model IngestJob {
  id         Int              @id @default(autoincrement())
  sourcePath String           @map("source_path")
  targetId   Int?             @map("target_id")
  status     IngestStatus     @default(PENDING)
  checksum   String?          @db.VarChar(64)
  proxyPath  String?          @map("proxy_path")
  metadata   Json?
  errorMsg   String?          @map("error_msg")
  startedAt  DateTime?        @map("started_at")
  finishedAt DateTime?        @map("finished_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @default(now()) @updatedAt @map("updated_at")
  deleted_at DateTime?
  planItems  IngestPlanItem[]
  qcReport   QcReport?

  @@index([status])
  @@index([targetId])
  @@map("ingest_jobs")
}

model IngestPlanItem {
  id                 Int                  @id @default(autoincrement())
  sourceType         String               @map("source_type") @db.VarChar(30)
  sourceKey          String               @unique @map("source_key") @db.VarChar(500)
  dayDate            DateTime             @map("day_date") @db.Date
  sourcePath         String?              @map("source_path")
  plannedStartMinute Int?                 @map("planned_start_minute")
  plannedEndMinute   Int?                 @map("planned_end_minute")
  status             IngestPlanStatus     @default(WAITING)
  jobId              Int?                 @map("job_id")
  note               String?
  updatedBy          String?              @map("updated_by") @db.VarChar(100)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  deleted_at         DateTime?
  job                IngestJob?           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  ports              IngestPlanItemPort[]

  @@index([dayDate])
  @@index([status])
  @@index([jobId])
  @@index([dayDate, plannedStartMinute, sourceKey], map: "ingest_plan_items_report_idx")
  @@map("ingest_plan_items")
}

/// Ana + yedek kayıt portu atamaları. 1 plan item = 1..2 port (primary + opsiyonel backup).
/// Cross-role overlap kontrolü tek GiST exclusion ile DB seviyesinde garanti edilir
/// (port meşgulse rol farkı yok). day_date ve start/end alanları parent'tan kopyalanır
/// (denormalized) — app layer Prisma $transaction ile sync tutar.
model IngestPlanItemPort {
  id                 Int            @id @default(autoincrement())
  planItemId         Int            @map("plan_item_id")
  portName           String         @map("port_name") @db.VarChar(50)
  role               String         @db.VarChar(20)
  dayDate            DateTime       @map("day_date") @db.Date
  plannedStartMinute Int            @map("planned_start_minute")
  plannedEndMinute   Int            @map("planned_end_minute")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  planItem           IngestPlanItem @relation(fields: [planItemId], references: [id], onDelete: Cascade)

  @@unique([planItemId, role], map: "ingest_plan_item_ports_role_unique")
  @@unique([planItemId, portName], map: "ingest_plan_item_ports_port_per_item_unique")
  @@index([planItemId], map: "ingest_plan_item_ports_plan_item_idx")
  @@index([dayDate, portName], map: "ingest_plan_item_ports_day_idx")
  @@map("ingest_plan_item_ports")
}

model RecordingPort {
  id         Int       @id @default(autoincrement())
  name       String    @unique @db.VarChar(50)
  sortOrder  Int       @default(0) @map("sort_order")
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deleted_at DateTime?

  @@index([active, sortOrder])
  @@map("recording_ports")
}

model QcReport {
  id         Int       @id @default(autoincrement())
  jobId      Int       @unique @map("job_id")
  codec      String?   @db.VarChar(50)
  resolution String?   @db.VarChar(20)
  duration   Float?
  frameRate  Float?    @map("frame_rate")
  bitrate    Int?
  loudness   Float?
  errors     Json?
  warnings   Json?
  passed     Boolean   @default(false)
  createdAt  DateTime  @default(now()) @map("created_at")
  // MED-INF-001 fix (2026-05-05): updatedAt eklendi (audit trail tutarlılığı).
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")
  deleted_at DateTime?
  job        IngestJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("qc_reports")
}

model Incident {
  id          Int              @id @default(autoincrement())
  scheduleId  Int?             @map("schedule_id")
  eventType   String           @map("event_type") @db.VarChar(50)
  description String?
  tcIn        String?          @map("tc_in") @db.VarChar(12)
  severity    IncidentSeverity @default(INFO)
  resolved    Boolean          @default(false)
  resolvedBy  String?          @map("resolved_by") @db.VarChar(100)
  resolvedAt  DateTime?        @map("resolved_at")
  metadata    Json?
  createdAt   DateTime         @default(now()) @map("created_at")
  deleted_at  DateTime?
  schedule    Schedule?        @relation(fields: [scheduleId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([scheduleId, severity])
  @@index([resolved, severity])
  @@map("incidents")
}

model TimelineEvent {
  id         Int       @id @default(autoincrement())
  scheduleId Int       @map("schedule_id")
  tc         String    @db.VarChar(12)
  type       String    @db.VarChar(50)
  note       String?
  createdBy  String    @map("created_by") @db.VarChar(100)
  createdAt  DateTime  @default(now()) @map("created_at")
  deleted_at DateTime?
  schedule   Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@map("timeline_events")
}

model StudioPlan {
  id         Int              @id @default(autoincrement())
  weekStart  DateTime         @unique @map("week_start") @db.Date
  version    Int              @default(1)
  createdBy  String           @map("created_by") @db.VarChar(100)
  updatedBy  String?          @map("updated_by") @db.VarChar(100)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  deleted_at DateTime?
  slots      StudioPlanSlot[]

  @@map("studio_plans")
}

model StudioPlanSlot {
  id          Int        @id @default(autoincrement())
  planId      Int        @map("plan_id")
  dayDate     DateTime   @map("day_date") @db.Date
  studio      String     @db.VarChar(100)
  startMinute Int        @map("start_minute")
  program     String     @db.VarChar(300)
  color       String     @db.VarChar(20)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deleted_at  DateTime?
  plan        StudioPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, dayDate, studio, startMinute])
  @@index([dayDate, studio])
  @@map("studio_plan_slots")
}

model StudioPlanProgram {
  id         Int       @id @default(autoincrement())
  name       String    @unique @db.VarChar(300)
  sortOrder  Int       @default(0) @map("sort_order")
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deleted_at DateTime?

  @@index([active, sortOrder])
  @@map("studio_plan_programs")
}

model StudioPlanColor {
  id         Int       @id @default(autoincrement())
  label      String    @unique @db.VarChar(100)
  value      String    @unique @db.VarChar(20)
  sortOrder  Int       @default(0) @map("sort_order")
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deleted_at DateTime?

  @@index([active, sortOrder])
  @@map("studio_plan_colors")
}

model SignalTelemetry {
  id         Int                     @id @default(autoincrement())
  channelId  Int                     @map("channel_id")
  signalDb   Float?                  @map("signal_db")
  snr        Float?
  ber        Float?
  audioLufs  Float?                  @map("audio_lufs")
  status     signal_telemetry_status @default(OK)
  source     String?                 @db.VarChar(50)
  measuredAt DateTime                @default(now()) @map("measured_at")
  deleted_at DateTime?
  channel    Channel                 @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, measuredAt])
  @@map("signal_telemetry")
}

/// Madde 1 PR-1A (audit doc): declarative range partitioning by `timestamp` (monthly).
/// Migration: 20260505000002_audit_log_partition_v1.
/// PG kuralı: partition key tüm PK/UNIQUE constraint'lerinde olmalı → composite
/// `(id, timestamp)` PK. Field-level `@id` KALDIRILDI; `@@id([id, timestamp])`
/// model-level kullanıldı. Pre-flight (2026-05-05): kodda id-tek-kolon lookup
/// yok (auditLog.findUnique by id, update, delete by id grep boş) → blast
/// radius zero.
///
/// Etki: Prisma `findUnique` selector artık composite (`{ id_timestamp: { id, timestamp } }`).
/// Mevcut kullanım: `findFirst`, `findMany`, `count`, `createMany`, `deleteMany` —
/// hepsi composite-PK uyumlu (id-only selector yok).
///
/// Retention job (`audit-retention.job.ts`) PR-1B feature-detect refactor'da
/// DROP PARTITION pattern'ine geçer; PR-1A retention'a dokunmaz.
model AuditLog {
  id            Int            @default(autoincrement())
  entityType    String         @map("entity_type") @db.VarChar(50)
  entityId      Int            @map("entity_id")
  action        AuditLogAction
  beforePayload Json?          @map("before_payload")
  afterPayload  Json?          @map("after_payload")
  user          String         @db.VarChar(100)
  ipAddress     String?        @map("ip_address") @db.VarChar(45)
  timestamp     DateTime       @default(now()) @db.Timestamptz(6)
  deleted_at    DateTime?

  @@id([id, timestamp])
  @@index([entityType, entityId])
  @@index([user])
  @@index([timestamp])
  @@map("audit_logs")
}

/// Madde 2+7 PR-A (audit doc): Outbox + DLQ V1 — schema foundation.
/// Tasarım: ops/REQUIREMENTS-OUTBOX-DLQ-V1.md
/// Migration: 20260506000000_outbox_events
///
/// DB seviyesinde CHECK constraint: status IN ('pending','published','failed','dead').
/// Prisma 5 native CHECK desteklemediği için bu yorum drift uyarısı görevi yapar
/// (Madde 4 usageScope ile aynı pattern).
///
/// Payload object convention: envelope helper (outbox.types.ts) object yazar;
/// DB sadece JSONB type-check eder; non-object (örn. string) yazımı bloklamaz.
/// Ek koruma katmanı: caller `createEnvelope()` helper'ı kullanmalı.
///
/// PR-A scope: sadece schema foundation. Poller, service refactor, admin endpoint,
/// metric → PR-B/C/D.
model OutboxEvent {
  id             Int       @id @default(autoincrement())
  /// UUID v4 (crypto.randomUUID() = 36 char); idempotency anchor.
  eventId        String    @unique @map("event_id") @db.VarChar(36)
  eventType      String    @map("event_type") @db.VarChar(100)
  aggregateType  String    @map("aggregate_type") @db.VarChar(50)
  aggregateId    String    @map("aggregate_id") @db.VarChar(50)
  schemaVersion  Int       @default(1) @map("schema_version")
  payload        Json
  /// CHECK enum: pending | published | failed | dead. Bkz schema header yorumu.
  status         String    @default("pending") @db.VarChar(20)
  attempts       Int       @default(0)
  lastError      String?   @map("last_error")
  occurredAt     DateTime  @map("occurred_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  publishedAt    DateTime? @map("published_at") @db.Timestamptz(6)
  /// Poller bu zaman geçince tekrar dener (backoff schedule).
  nextAttemptAt  DateTime  @default(now()) @map("next_attempt_at") @db.Timestamptz(6)
  /// Madde 2+7 PR-B3b-2 schema PR: aggregate-level idempotency key. Cross-producer
  /// dedup (örn. INGEST_COMPLETED — Node worker + Avid capture callback aynı job için).
  /// Format: `{eventType}:{aggregateType}:{aggregateId}:{discriminator}` (ör.
  /// `ingest.job_completed:IngestJob:42:COMPLETED`). Tüm domain event'ler için
  /// zorunlu DEĞİL — yalnız cross-producer dedup gereken event'lerde set edilir.
  /// DB UNIQUE: partial unique index (`WHERE idempotency_key IS NOT NULL`) — bu
  /// migration SQL'de + test interim helper'da uygulanır; Prisma 5 partial @@unique
  /// desteği sınırlı olduğu için schema'da @@unique YAZMAYINIZ.
  idempotencyKey String?   @map("idempotency_key") @db.VarChar(160)

  @@index([status, nextAttemptAt], map: "outbox_events_status_next_attempt_idx") // poller hot-path
  @@index([aggregateType, aggregateId], map: "outbox_events_aggregate_idx") // lookup/replay
  @@index([eventType], map: "outbox_events_event_type_idx")
  @@map("outbox_events")
}

model ShiftAssignment {
  id        Int       @id @default(autoincrement())
  userId    String    @map("user_id") @db.VarChar(100)
  userName  String    @map("user_name") @db.VarChar(100)
  userGroup String    @map("user_group") @db.VarChar(50)
  weekStart String    @map("week_start") @db.VarChar(10)
  dayIndex  Int       @map("day_index")
  startTime String?   @map("start_time") @db.VarChar(5)
  endTime   String?   @map("end_time") @db.VarChar(5)
  type      String    @db.VarChar(20)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt DateTime? @map("deleted_at")

  @@unique([userId, weekStart, dayIndex])
  @@index([userId, weekStart], map: "idx_shift_user_week")
  @@index([weekStart, userGroup], map: "idx_shift_week_group")
  @@map("shift_assignments")
}

/// Madde 5 M5-B1 (audit doc): live-plan canonical üst entity — yayın akışı
/// (Schedule) ile karıştırılmaması için ayrı tablo.
/// Tasarım: ops/DECISION-LIVE-PLAN-DATA-MODEL-V1.md §3.2 (M5-B1 Scope Lock)
/// Migration: 20260506000002_live_plan_entries_foundation
///
/// Locked decisions (K1..K6, 2026-05-06):
///   K1 — matchId + optaMatchId nullable; opta_match_id unique DEĞİL.
///   K2 — LivePlanStatus = PLANNED/READY/IN_PROGRESS/COMPLETED/CANCELLED.
///   K3 — version optimistic locking (M5-B2 If-Match).
///   K4 — audit subject "LivePlanEntry" (M5-B2 service writes).
///   K5 — canonical /api/v1/live-plan (M5-B2; shim YOK).
///   K6 — schema foundation only; createdBy nullable.
///
/// M5-B1 KAPSAM: tablo + enum + 4 index + Match FK SetNull. Service/route/UI
/// /ingest FK/cleanup/outbox shadow KAPSAM DIŞI (sırayla M5-B2..B5).
model LivePlanEntry {
  id             Int            @id @default(autoincrement())
  title          String         @db.VarChar(500)
  eventStartTime DateTime       @map("event_start_time") @db.Timestamptz(6)
  eventEndTime   DateTime       @map("event_end_time") @db.Timestamptz(6)
  /// Internal Match FK; nullable çünkü her live-plan futbol maçı olmak zorunda
  /// değil (bant içerik, manuel event, stüdyo kaynaklı içerik mümkün).
  matchId        Int?           @map("match_id")
  /// External OPTA identity; unique DEĞİL — aynı OPTA event'ten birden fazla
  /// operasyon planı doğabilir. metadata.optaMatchId JSON fallback YOK
  /// (Madde 3 PR-3A transition pattern Schedule içindi; live_plan_entries
  /// temiz başlar).
  optaMatchId    String?        @map("opta_match_id") @db.VarChar(80)
  status         LivePlanStatus @default(PLANNED)
  operationNotes String?        @map("operation_notes")
  /// M5-B2 route-level kural: kullanıcı işlemlerinde doldur. Script/seed/
  /// system import için nullable bırakıldı.
  createdBy      String?        @map("created_by") @db.VarChar(100)
  /// Optimistic locking (Schedule/Booking ile aynı pattern; M5-B2 If-Match).
  version        Int            @default(1)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  match            Match?                   @relation(fields: [matchId], references: [id], onDelete: SetNull)
  /// Madde 5 M5-B7 (decision §5 + scope lock S2, 2026-05-07): 1:1 child;
  /// live_plan_technical_details.live_plan_entry_id UNIQUE NOT NULL
  /// FK ON DELETE CASCADE. Reverse relation optional (henüz oluşturulmamış
  /// olabilir). 25 lookup FK scalar-only Prisma model'inde — relation
  /// tanımlanmadı (47 reverse field'ı önlemek için pragmatik tercih;
