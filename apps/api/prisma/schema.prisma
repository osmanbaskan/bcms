/// Madde 5 M5-B7 (decision sec. 5 + scope lock S1-S12, 2026-05-07):
/// live-plan teknik detayları — 1:1 ile LivePlanEntry. ~73 domain alani + 5
/// sistem kolonu + deleted_at = ~79 kolon (K15.2 revize: tek satir;
/// backup_ ve fiber_ prefixleri; eski K15.2 W1-W4 per-feed split iptal).
///
/// 25 lookup FK scalar-only — Prisma relation attribute tanimlanmadi;
/// reverse field patlamasini (47 array) onlemek icin pragmatik tercih.
/// Service M5-B9: include yerine manuel prisma lookup findUnique ile join.
///
/// CHECK ve UNIQUE constraintleri schema.prisma yerine migration SQL ile
/// uygulanir (Prisma 5 sinirli CHECK destegi). Test interim helper db push
/// sonrasi bu constraintleri yeniden uygular (Madde 4 pattern).
model LivePlanTechnicalDetail {
  id              Int       @id @default(autoincrement())
  livePlanEntryId Int       @unique @map("live_plan_entry_id")
  /// Optimistic locking (K9 — Schedule/Booking/LivePlan ile aynı pattern;
  /// If-Match enforce M5-B9 service'inde).
  version         Int       @default(1)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  // §5.1 Yayın/OB grubu (14)
  broadcastLocationId Int?    @map("broadcast_location_id")
  obVanCompanyId      Int?    @map("ob_van_company_id")
  generatorCompanyId  Int?    @map("generator_company_id")
  jimmyJibId          Int?    @map("jimmy_jib_id")
  steadicamId         Int?    @map("steadicam_id")
  sngCompanyId        Int?    @map("sng_company_id")
  carrierCompanyId    Int?    @map("carrier_company_id")
  ibmId               Int?    @map("ibm_id")
  usageLocationId     Int?    @map("usage_location_id")
  fixedPhone1         String? @map("fixed_phone_1") @db.VarChar(80)
  secondObVanId       Int?    @map("second_ob_van_id")
  regionId            Int?    @map("region_id")
  cameraCount         Int?    @map("camera_count")
  fixedPhone2         String? @map("fixed_phone_2") @db.VarChar(80)

  // §5.2 Ortak (10)
  plannedStartTime  DateTime? @map("planned_start_time") @db.Timestamptz(6)
  plannedEndTime    DateTime? @map("planned_end_time") @db.Timestamptz(6)
  hdvgResourceId    Int?      @map("hdvg_resource_id")
  int1ResourceId    Int?      @map("int1_resource_id")
  int2ResourceId    Int?      @map("int2_resource_id")
  offTubeId         Int?      @map("off_tube_id")
  languageId        Int?      @map("language_id")
  demodId           Int?      @map("demod_id")
  tieId             Int?      @map("tie_id")
  virtualResourceId Int?      @map("virtual_resource_id")

  // §5.3 IRD/Fiber (5)
  ird1Id   Int? @map("ird1_id")
  ird2Id   Int? @map("ird2_id")
  ird3Id   Int? @map("ird3_id")
  fiber1Id Int? @map("fiber1_id")
  fiber2Id Int? @map("fiber2_id")

  // §5.4 Ana Feed (21)
  feedTypeId             Int?    @map("feed_type_id")
  satelliteId            Int?    @map("satellite_id")
  txp                    String? @db.VarChar(120)
  satChannel             String? @map("sat_channel") @db.VarChar(120)
  uplinkFrequency        String? @map("uplink_frequency") @db.VarChar(120)
  uplinkPolarizationId   Int?    @map("uplink_polarization_id")
  downlinkFrequency      String? @map("downlink_frequency") @db.VarChar(120)
  downlinkPolarizationId Int?    @map("downlink_polarization_id")
  modulationTypeId       Int?    @map("modulation_type_id")
  rollOffId              Int?    @map("roll_off_id")
  videoCodingId          Int?    @map("video_coding_id")
  audioConfigId          Int?    @map("audio_config_id")
  preMatchKey            String? @map("pre_match_key") @db.VarChar(200)
  matchKey               String? @map("match_key") @db.VarChar(200)
  postMatchKey           String? @map("post_match_key") @db.VarChar(200)
  isoFeedId              Int?    @map("iso_feed_id")
  keyTypeId              Int?    @map("key_type_id")
  symbolRate             String? @map("symbol_rate") @db.VarChar(80)
  fecRateId              Int?    @map("fec_rate_id")
  bandwidth              String? @db.VarChar(80)
  uplinkFixedPhone       String? @map("uplink_fixed_phone") @db.VarChar(80)

  // §5.5 Yedek Feed (19)
  backupFeedTypeId             Int?    @map("backup_feed_type_id")
  backupSatelliteId            Int?    @map("backup_satellite_id")
  backupTxp                    String? @map("backup_txp") @db.VarChar(120)
  backupSatChannel             String? @map("backup_sat_channel") @db.VarChar(120)
  backupUplinkFrequency        String? @map("backup_uplink_frequency") @db.VarChar(120)
