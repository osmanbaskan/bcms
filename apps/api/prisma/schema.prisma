  backupDownlinkFrequency      String? @map("backup_downlink_frequency") @db.VarChar(120)
  backupDownlinkPolarizationId Int?    @map("backup_downlink_polarization_id")
  backupModulationTypeId       Int?    @map("backup_modulation_type_id")
  backupRollOffId              Int?    @map("backup_roll_off_id")
  backupVideoCodingId          Int?    @map("backup_video_coding_id")
