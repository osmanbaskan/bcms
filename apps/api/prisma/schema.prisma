  backupFecRateId              Int?    @map("backup_fec_rate_id")
  backupBandwidth              String? @map("backup_bandwidth") @db.VarChar(80)

  // §5.6 Fiber (4)
  fiberCompanyId     Int?    @map("fiber_company_id")
  fiberAudioFormatId Int?    @map("fiber_audio_format_id")
  fiberVideoFormatId Int?    @map("fiber_video_format_id")
  fiberBandwidth     String? @map("fiber_bandwidth") @db.VarChar(80)

  /// Parent FK CASCADE (S4). Schema-only PR; service M5-B9 If-Match.
  livePlanEntry LivePlanEntry @relation(fields: [livePlanEntryId], references: [id], onDelete: Cascade)

  @@map("live_plan_technical_details")
